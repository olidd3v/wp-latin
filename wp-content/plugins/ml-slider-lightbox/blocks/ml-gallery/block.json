{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ml-slider-lightbox/gallery",
  "title": "MetaSlider Gallery",
  "category": "media",
"description": "Display a MetaSlider Gallery.",
